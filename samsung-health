<!DOCTYPE html>
<html lang="ko">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
<title>삼성헬스 — FaceAge 통합 시안 v3</title>
<link href="https://cdn.jsdelivr.net/gh/orioncactus/pretendard@v1.3.9/dist/web/static/pretendard.min.css" rel="stylesheet">
<style>
  /* === 삼성헬스 토큰 (실제 앱 정확히 측정) === */
  :root {
    --bg-page: #F2F3F5;        /* 페이지 배경 */
    --bg-card: #FFFFFF;
    --line: #E8EAED;
    --line-strong: #D9DCE0;

    /* 텍스트 — 매우 진한 흑색 위주 */
    --text-1: #0E1116;         /* 거의 검정 */
    --text-2: #3A3F47;
    --text-3: #767B85;
    --text-4: #ABAFB8;

    --shadow-card: 0 1px 2px rgba(0,0,0,0.03);

    /* 카테고리 액센트 (절제) - 실제 삼성헬스 톤 */
    --c-activity: #00B574;     /* 활동 그린 */
    --c-steps: #F5B92E;        /* 걸음 황금 */
    --c-heart: #FF4D5E;
    --c-sleep: #6F5BE8;
    --c-food: #FF7A3D;
    --c-water: #4FB5F0;
    --c-weight: #5B7BD1;
    --c-distance: #00B574;

    /* FaceAge 시그니처 (유지) */
    --c-faceage: #3182F6;
    --c-faceage-deep: #1B64DA;
    --c-faceage-soft: #E8F0FE;
    --c-younger: #00C896;
    --c-older: #FF7B5C;
  }

  * { box-sizing: border-box; -webkit-tap-highlight-color: transparent; }
  html, body { margin: 0; padding: 0; background: var(--bg-page); }
  body {
    font-family: 'Pretendard', -apple-system, BlinkMacSystemFont, sans-serif;
    color: var(--text-1);
    font-size: 14px;
    line-height: 1.35;
    -webkit-font-smoothing: antialiased;
    letter-spacing: -0.3px;
  }

  /* v1.1: 시안 안내 띠 (페이지 최상단) */
  .demo-banner {
    background: linear-gradient(135deg, #3182F6 0%, #1B64DA 100%);
    color: #fff;
    padding: 10px 14px;
    display: flex; align-items: center; gap: 10px;
    position: sticky; top: 0; z-index: 200;
    font-size: 12px;
  }
  .demo-back-btn {
    display: inline-flex; align-items: center; gap: 5px;
    background: rgba(255,255,255,0.18);
    color: #fff;
    border: none;
    padding: 6px 10px 6px 8px;
    border-radius: 100px;
    font-size: 12px; font-weight: 700;
    font-family: inherit;
    cursor: pointer;
    flex-shrink: 0;
    transition: background 0.15s, transform 0.1s;
    letter-spacing: -0.2px;
  }
  .demo-back-btn:active {
    background: rgba(255,255,255,0.30);
    transform: scale(0.97);
  }
  .demo-banner-text {
    flex: 1; min-width: 0;
    text-align: right;
    font-weight: 600;
    opacity: 0.92;
    letter-spacing: -0.2px;
  }

  /* 모바일 컨테이너 */
  #app {
    max-width: 440px;
    margin: 0 auto;
    min-height: 100vh;
    background: var(--bg-page);
    padding-bottom: 80px;
    position: relative;
  }
  /* Z폴드 펼친 모드 - 2열 유지하면서 컨테이너 넓어짐 */
  @media (min-width: 600px) { #app { max-width: 560px; } }
  @media (min-width: 768px) { #app { max-width: 720px; } }
  @media (min-width: 1024px) { #app { max-width: 880px; } }

  /* === Status bar === */
  .status-bar {
    display: flex; justify-content: space-between; align-items: center;
    padding: 12px 22px 4px;
    font-size: 15px; font-weight: 600;
    color: var(--text-1);
  }
  .status-bar-right {
    display: flex; gap: 6px; align-items: center;
  }
  .status-bar-right svg { display: block; }

  /* === 헤더 큰 폰트 === */
  .top-header {
    padding: 10px 22px 6px;
    display: flex; justify-content: space-between; align-items: center;
  }
  .header-title {
    font-size: 28px; font-weight: 700;
    letter-spacing: -0.6px; color: var(--text-1);
  }
  .header-icons { display: flex; gap: 2px; }
  .header-icon-btn {
    background: transparent; border: none;
    width: 40px; height: 40px;
    border-radius: 12px;
    display: flex; align-items: center; justify-content: center;
    color: var(--text-1); cursor: pointer; padding: 0;
  }
  .header-icon-btn:active { background: rgba(0,0,0,0.06); }
  .header-icon-btn svg { width: 24px; height: 24px; }

  /* === 활동 요약 큰 카드 (Activity 3링) === */
  .activity-card {
    background: var(--bg-card);
    border-radius: 24px;
    margin: 8px 16px 8px;
    padding: 22px 24px;
    box-shadow: var(--shadow-card);
    cursor: pointer;
  }
  .activity-card-header {
    display: flex; justify-content: space-between; align-items: center;
    margin-bottom: 18px;
  }
  .activity-card-title {
    font-size: 17px; font-weight: 700;
    color: var(--text-1);
    letter-spacing: -0.4px;
  }
  .activity-card-date {
    font-size: 13px; color: var(--text-3);
    font-weight: 500;
  }
  .activity-rings-row {
    display: flex; align-items: center; gap: 16px;
  }
  .activity-rings-wrap {
    position: relative;
    width: 110px; height: 110px;
    flex-shrink: 0;
  }
  .activity-rings-wrap svg {
    width: 110px; height: 110px;
    transform: rotate(-90deg);
  }
  .activity-ring-bg-1 { fill: none; stroke: #F0F2F5; stroke-width: 8; }
  .activity-ring-bg-2 { fill: none; stroke: #F0F2F5; stroke-width: 8; }
  .activity-ring-bg-3 { fill: none; stroke: #F0F2F5; stroke-width: 8; }
  .activity-ring-1 { fill: none; stroke: var(--c-activity); stroke-width: 8; stroke-linecap: round; }
  .activity-ring-2 { fill: none; stroke: var(--c-steps); stroke-width: 8; stroke-linecap: round; }
  .activity-ring-3 { fill: none; stroke: var(--c-heart); stroke-width: 8; stroke-linecap: round; }

  .activity-stats { flex: 1; }
  .activity-stat-row {
    display: flex; align-items: center; gap: 10px;
    padding: 5px 0;
  }
  .activity-stat-dot {
    width: 10px; height: 10px;
    border-radius: 50%;
    flex-shrink: 0;
  }
  .activity-stat-label {
    flex: 1; font-size: 13px; color: var(--text-3);
    font-weight: 500;
  }
  .activity-stat-value {
    font-size: 16px; font-weight: 700;
    color: var(--text-1);
    font-variant-numeric: tabular-nums;
    letter-spacing: -0.3px;
  }
  .activity-stat-value .unit {
    font-size: 11px; color: var(--text-3);
    font-weight: 500;
    margin-left: 1px;
  }

  /* === 2열 타일 그리드 === */
  .tile-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 8px;
    padding: 0 16px;
    margin-bottom: 8px;
  }
  /* 폴드 펼친 모드 — 4열로 확장 */
  @media (min-width: 768px) {
    .tile-grid {
      grid-template-columns: 1fr 1fr 1fr 1fr;
      gap: 10px;
    }
  }

  .tile {
    background: var(--bg-card);
    border-radius: 22px;
    padding: 18px 18px 20px;
    box-shadow: var(--shadow-card);
    cursor: pointer;
    transition: background 0.15s, transform 0.1s;
    min-height: 168px;
    display: flex; flex-direction: column;
  }
  .tile:active { background: #FAFBFC; transform: scale(0.98); }

  .tile-header {
    display: flex; align-items: center; gap: 8px;
    margin-bottom: 16px;
  }
  .tile-icon {
    width: 28px; height: 28px;
    border-radius: 50%;
    display: flex; align-items: center; justify-content: center;
    flex-shrink: 0;
  }
  .tile-icon svg { width: 16px; height: 16px; }
  .tile-label {
    font-size: 15px; font-weight: 600;
    color: var(--text-1); flex: 1; min-width: 0;
    letter-spacing: -0.4px;
  }

  .tile-body {
    flex: 1;
    display: flex; flex-direction: column;
    justify-content: flex-end;
  }
  .tile-value-row {
    display: flex; align-items: baseline; gap: 3px;
    margin-bottom: 4px;
  }
  /* === 메인 데이터 폰트 — 38px === */
  .tile-value {
    font-size: 38px; font-weight: 700;
    color: var(--text-1);
    line-height: 1;
    letter-spacing: -1px;
    font-variant-numeric: tabular-nums;
  }
  .tile-unit {
    font-size: 14px; color: var(--text-2);
    font-weight: 600;
    letter-spacing: -0.3px;
  }
  .tile-sub {
    font-size: 12.5px; color: var(--text-3);
    font-weight: 500;
    margin-top: 2px;
    letter-spacing: -0.2px;
  }
  .tile-trend {
    display: inline-flex; align-items: center; gap: 3px;
    font-size: 12px; font-weight: 600;
    margin-top: 3px;
  }
  .tile-trend.up { color: var(--c-activity); }
  .tile-trend.down { color: var(--c-heart); }

  /* === FaceAge 와이드 타일 (2칸 차지) === */
  .tile-wide {
    grid-column: span 2;
    min-height: 168px;
  }
  /* 폴드에서는 폭이 더 크니까 4중 2 정도만 차지 */
  @media (min-width: 768px) {
    .tile-wide { grid-column: span 2; }
  }

  /* ⭐ FaceAge 타일 (특별) */
  .faceage-tile {
    background: linear-gradient(135deg, #FFFFFF 0%, var(--c-faceage-soft) 100%);
    border-radius: 22px;
    padding: 18px 18px 20px;
    box-shadow: var(--shadow-card);
    cursor: pointer;
    position: relative;
    overflow: hidden;
    transition: transform 0.1s;
    grid-column: span 2;
    min-height: 168px;
    display: flex; flex-direction: column;
  }
  .faceage-tile:active { transform: scale(0.99); }
  /* 우상단 데코 */
  .faceage-tile::after {
    content: ''; position: absolute;
    top: -30px; right: -30px;
    width: 120px; height: 120px;
    background: radial-gradient(circle, rgba(49,130,246,0.10), transparent 65%);
    border-radius: 50%;
    pointer-events: none;
  }
  .faceage-tile-header {
    display: flex; align-items: center; gap: 8px;
    margin-bottom: 14px; position: relative; z-index: 1;
  }
  .faceage-tile-header .tile-icon {
    background: var(--c-faceage);
    color: #fff;
  }
  .faceage-new-badge {
    background: var(--c-faceage);
    color: #fff;
    font-size: 10px; font-weight: 700;
    padding: 2px 7px;
    border-radius: 100px;
    letter-spacing: 0.5px;
    line-height: 1;
  }

  .faceage-body {
    flex: 1;
    display: flex; align-items: center; gap: 16px;
    position: relative; z-index: 1;
  }
  .faceage-hero {
    flex-shrink: 0;
  }
  .faceage-hero-row {
    display: flex; align-items: baseline; gap: 4px;
    margin-bottom: 2px;
  }
  /* === FaceAge 메인 데이터 — 38px === */
  .faceage-delta {
    font-size: 38px; font-weight: 700;
    line-height: 1;
    letter-spacing: -1px;
    color: var(--c-younger);
    font-variant-numeric: tabular-nums;
  }
  .faceage-delta-unit {
    font-size: 14px; font-weight: 600;
    color: var(--c-younger);
    letter-spacing: -0.3px;
  }
  .faceage-sub {
    font-size: 12.5px; color: var(--text-3);
    font-weight: 500;
    margin-bottom: 6px;
  }
  .faceage-tag {
    display: inline-block;
    padding: 3px 9px;
    background: rgba(0,200,150,0.13);
    color: var(--c-younger);
    font-size: 11.5px;
    font-weight: 700;
    border-radius: 100px;
    letter-spacing: -0.2px;
  }
  /* 우측 미니 스파크라인 */
  .faceage-spark {
    flex: 1; min-width: 0;
    height: 56px;
  }
  .faceage-spark svg {
    width: 100%; height: 100%;
    display: block; overflow: visible;
  }
  .faceage-spark-base {
    stroke: var(--line-strong);
    stroke-width: 1;
    stroke-dasharray: 2 3;
  }
  .faceage-spark-area { fill: rgba(0,200,150,0.16); }
  .faceage-spark-line {
    fill: none;
    stroke: var(--c-faceage);
    stroke-width: 2;
    stroke-linecap: round;
    stroke-linejoin: round;
  }
  .faceage-spark-dot {
    fill: var(--c-faceage);
    stroke: #fff;
    stroke-width: 1.5;
  }
  .faceage-spark-dot.current {
    fill: var(--c-younger);
  }

  /* === 미니 차트들 (각 타일별) === */
  /* 심박 파동 */
  .mini-heart-line {
    margin-top: 6px;
    height: 26px;
  }
  /* 수면 막대 */
  .mini-sleep-bars {
    margin-top: 6px;
    display: flex; gap: 2px; align-items: flex-end;
    height: 26px;
  }
  .mini-sleep-bars span {
    flex: 1; background: var(--c-sleep);
    border-radius: 2px;
    opacity: 0.7;
  }
  /* 운동 7일 막대 */
  .mini-week-bars {
    margin-top: 6px;
    display: flex; gap: 3px; align-items: flex-end;
    height: 26px;
  }
  .mini-week-bars span {
    flex: 1; border-radius: 2px;
    min-height: 4px;
  }

  /* === 섹션 헤더 === */
  .section-header {
    padding: 18px 22px 8px;
    display: flex; justify-content: space-between; align-items: baseline;
  }
  .section-header-title {
    font-size: 18px; font-weight: 700;
    color: var(--text-1);
    letter-spacing: -0.5px;
  }
  .section-header-more {
    font-size: 13px; color: var(--text-3);
    font-weight: 600;
  }

  /* === Tip 카드 === */
  .tip-card {
    background: var(--bg-card);
    border-radius: 18px;
    padding: 16px 18px;
    margin: 0 16px 8px;
    box-shadow: var(--shadow-card);
    display: flex; gap: 12px; align-items: center;
    cursor: pointer;
  }
  .tip-card:active { background: #FAFBFC; }
  .tip-card-icon {
    width: 42px; height: 42px;
    border-radius: 12px;
    display: flex; align-items: center; justify-content: center;
    flex-shrink: 0;
  }
  .tip-card-icon svg { width: 20px; height: 20px; }
  .tip-card-body { flex: 1; min-width: 0; }
  .tip-card-title {
    font-size: 14.5px; font-weight: 600;
    color: var(--text-1);
    letter-spacing: -0.3px;
    line-height: 1.35;
    margin-bottom: 3px;
  }
  .tip-card-desc {
    font-size: 12.5px; color: var(--text-3);
    line-height: 1.5;
    font-weight: 500;
  }
  .tip-card-arrow {
    color: var(--text-4); flex-shrink: 0;
  }
  .tip-card-arrow svg { width: 18px; height: 18px; }

  /* === 하단 탭바 === */
  .bottom-tabs {
    position: fixed;
    bottom: 0; left: 50%;
    transform: translateX(-50%);
    width: 100%;
    max-width: 440px;
    background: rgba(255,255,255,0.97);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    border-top: 1px solid var(--line);
    display: flex;
    padding: 6px 0 calc(8px + env(safe-area-inset-bottom, 0));
    z-index: 100;
  }
  @media (min-width: 600px) { .bottom-tabs { max-width: 560px; } }
  @media (min-width: 768px) { .bottom-tabs { max-width: 720px; } }
  @media (min-width: 1024px) { .bottom-tabs { max-width: 880px; } }

  .bottom-tab {
    flex: 1;
    display: flex; flex-direction: column;
    align-items: center; gap: 3px;
    background: transparent; border: none;
    padding: 8px 4px;
    color: var(--text-3);
    font-size: 11px; font-weight: 600;
    cursor: pointer;
    font-family: inherit;
    letter-spacing: -0.2px;
  }
  .bottom-tab.active { color: var(--text-1); }
  .bottom-tab svg { width: 24px; height: 24px; }

  /* 컬러 헬퍼 */
  .ic-steps { background: #FFF4DC; color: var(--c-steps); }
  .ic-heart { background: #FFE7E9; color: var(--c-heart); }
  .ic-sleep { background: #ECE9FE; color: var(--c-sleep); }
  .ic-activity { background: #E0F7EE; color: var(--c-activity); }
  .ic-food { background: #FFEAD7; color: var(--c-food); }
  .ic-water { background: #E2F2FC; color: var(--c-water); }
  .ic-weight { background: #E8EEF8; color: var(--c-weight); }
  .ic-faceage { background: var(--c-faceage-soft); color: var(--c-faceage); }

  /* 토스트 */
  .toast {
    position: fixed;
    bottom: 90px; left: 50%;
    transform: translateX(-50%);
    background: rgba(15,15,24,0.92);
    color: #fff;
    padding: 12px 20px;
    border-radius: 100px;
    font-size: 13px;
    z-index: 9999;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.25s;
    max-width: 90%;
    text-align: center;
    box-shadow: 0 8px 24px rgba(0,0,0,0.2);
  }
  .toast.show { opacity: 1; }

  /* 진입 애니메이션 */
  @keyframes card-in {
    from { opacity: 0; transform: translateY(6px); }
    to { opacity: 1; transform: translateY(0); }
  }
  .activity-card, .tile, .faceage-tile, .tip-card {
    animation: card-in 0.32s ease both;
  }
  .activity-card { animation-delay: 0.02s; }
  .tile:nth-child(1), .faceage-tile { animation-delay: 0.06s; }
  .tile:nth-child(2) { animation-delay: 0.08s; }
  .tile:nth-child(3) { animation-delay: 0.10s; }
  .tile:nth-child(4) { animation-delay: 0.12s; }
  .tile:nth-child(5) { animation-delay: 0.14s; }
  .tip-card:nth-of-type(1) { animation-delay: 0.18s; }
  .tip-card:nth-of-type(2) { animation-delay: 0.20s; }
</style>
</head>
<body>

<!-- v1.1: 시안 안내 띠 (실제 삼성헬스 화면이 아니라 데모임을 명시) -->
<div class="demo-banner">
  <button class="demo-back-btn" onclick="goBackToFaceAge()" aria-label="FaceAge로 돌아가기">
    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
      <polyline points="15 18 9 12 15 6"/>
    </svg>
    FaceAge로 돌아가기
  </button>
  <div class="demo-banner-text">통합 시안 · 얼굴 나이 카드를 눌러보세요</div>
</div>

<div id="app">

  <!-- 상태바 -->
  <div class="status-bar">
    <span>9:41</span>
    <div class="status-bar-right">
      <svg width="16" height="11" viewBox="0 0 16 11" fill="currentColor">
        <path d="M0 8h2v3H0zm3-2h2v5H3zm3-2h2v7H6zm3-2h2v9H9zm3-2h2v11h-2z"/>
      </svg>
      <svg width="16" height="11" viewBox="0 0 16 11" fill="currentColor">
        <path d="M8 9c.55 0 1 .45 1 1H7c0-.55.45-1 1-1zm0-3c1.66 0 3.14.67 4.24 1.76l-1.41 1.41C9.95 8.45 9 8 8 8s-1.95.45-2.83 1.17L3.76 7.76A6 6 0 0 1 8 6zm0-3c2.49 0 4.74 1.01 6.36 2.64l-1.41 1.41A7 7 0 0 0 8 5a7 7 0 0 0-4.95 2.05L1.64 5.64A9 9 0 0 1 8 3z"/>
      </svg>
      <svg width="24" height="11" viewBox="0 0 24 11" fill="none">
        <rect x="1" y="1" width="20" height="9" rx="2" stroke="currentColor" stroke-width="1"/>
        <rect x="3" y="3" width="16" height="5" rx="1" fill="currentColor"/>
        <rect x="22" y="3.5" width="1.5" height="4" rx="0.5" fill="currentColor"/>
      </svg>
    </div>
  </div>

  <!-- 헤더 -->
  <div class="top-header">
    <div class="header-title">홈</div>
    <div class="header-icons">
      <button class="header-icon-btn" aria-label="검색">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <circle cx="11" cy="11" r="7"/>
          <line x1="21" y1="21" x2="16.65" y2="16.65"/>
        </svg>
      </button>
      <button class="header-icon-btn" aria-label="알림">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9"/>
          <path d="M13.73 21a2 2 0 0 1-3.46 0"/>
        </svg>
      </button>
      <button class="header-icon-btn" aria-label="설정">
